# ═══════════════════════════════════════════════════
# gcli-acc-gen environment variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Temp email (Cloudflare Worker mailbox) ──────────
# Required: secret path prefix for your mailbox worker
CF_MAILBOX_SECRET=your_32_char_secret_here
# Required: worker URL (e.g. https://your-mailbox.your-account.workers.dev)
WORKER_URL=https://your-mailbox.your-account.workers.dev

# ── 2captcha (Turnstile solver) ─────────────────────
# Required for signup: Grok uses Cloudflare Turnstile on the
# "Complete your sign up" screen.
# Get key at https://2captcha.com (v1 API, 32-char key)
# Either set env var OR place key in ~/.2captcha_key
TWOCAPTCHA_KEY=your_32_char_2captcha_key

# ── 9Router (optional — for auto OAuth registration) ─
# If you want --register-9router to work, set these:
NINEROUTER_HOST=http://localhost:20128
NINEROUTER_PASSWORD=your_9router_admin_password

# ── Browser ─────────────────────────────────────────
# Display for headed Camoufox (required on residential box with X)
DISPLAY=:0

# ── Mail provider (optional, default: cloudflare) ──
# Options: cloudflare (recommended), mailtm (public, no setup)
MAIL_PROVIDER=cloudflare
